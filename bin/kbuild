#!/usr/bin/env bash
#
# kbuild — run kernel make targets inside the kernel-builder container
#
# Usage:
#   kbuild menuconfig
#   kbuild -j$(nproc) bzImage modules
#   kbuild clean
#   kbuild ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- defconfig
#
# The script bind-mounts the current directory into the container so
# build artifacts land in your local tree, exactly like a native make.

set -euo pipefail

IMAGE_NAME="kernel-builder"
CONTAINER_OPTS=()

# If stdout is a terminal, enable interactive + tty (needed for menuconfig)
if [ -t 0 ] && [ -t 1 ]; then
    CONTAINER_OPTS+=("-it")
fi

# Pass through the calling user's UID/GID so output files aren't owned by root
HOST_UID=$(id -u)
HOST_GID=$(id -g)

exec docker run --rm \
    "${CONTAINER_OPTS[@]}" \
    --user "${HOST_UID}:${HOST_GID}" \
    -v "$(pwd):/src" \
    -e HOME=/tmp \
    "${IMAGE_NAME}" \
    make "$@"
