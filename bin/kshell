#!/usr/bin/env bash
#
# kshell — open an interactive shell inside the kernel-builder container
#          with the current directory mounted at /src
#
# Usage:
#   kshell              # bash as your user
#   kshell --root       # bash as root (install extra packages, etc.)

set -euo pipefail

IMAGE_NAME="kernel-builder"

if [[ "${1:-}" == "--root" ]]; then
    exec docker run --rm -it \
        -v "$(pwd):/src" \
        "${IMAGE_NAME}" \
        /bin/bash
else
    HOST_UID=$(id -u)
    HOST_GID=$(id -g)
    exec docker run --rm -it \
        --user "${HOST_UID}:${HOST_GID}" \
        -v "$(pwd):/src" \
        -e HOME=/tmp \
        "${IMAGE_NAME}" \
        /bin/bash
fi
