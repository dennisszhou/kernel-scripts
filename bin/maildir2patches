#!/usr/bin/python3

from __future__ import annotations

import argparse
import mailbox
import sys
import re
from dataclasses import dataclass
from email.message import Message
from pathlib import Path

PATCH_SUBJECT_PATTERNS = [
    re.compile(
        r"^\s*\[(?:.*?[^\d/])?\s*(?:[vV]\d*)?\s*(\d+)\s*(?:/\s*\d+)?\s*"
        r"(?:[^0-9/].*)?\]\s*((?:\S.*\S)|\S)",
        re.I,
    ),
    re.compile(r".*PATCH\s*(\d+)\s*(?:/\s*\d+)?\s*((?:\S.*\S)|\S)", re.I),
]
TRIM_SUBJECT_PATTERN = re.compile(r"^\s*(?:\[.*\])?(.*)")
UNKNOWN_PATCH_START = 9000
MAX_SUBJECT_STEM_LEN = 52


@dataclass
class OutputPatch:
    sort_key: tuple[int, int]
    filename: str


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Convert a Maildir mailbox into numbered patch files"
    )
    parser.add_argument("maildir", help="path to the Maildir input")
    parser.add_argument(
        "-o",
        "--output-dir",
        default=".",
        help="directory to write patch files into",
    )
    return parser.parse_args()


def format_subject(subject: str) -> str:
    out = []
    last_was_alnum = False
    for char in subject:
        if char.isalnum():
            out.append(char)
            last_was_alnum = True
            continue
        if last_was_alnum:
            out.append("_")
        last_was_alnum = False

    stem = "".join(out).strip("_").lower()
    if not stem:
        return "untitled"
    return stem[:MAX_SUBJECT_STEM_LEN]


def parse_patch_subject(subject: str, fallback_idx: int) -> tuple[int, str]:
    normalized = " ".join(subject.splitlines())

    for pattern in PATCH_SUBJECT_PATTERNS:
        match = pattern.match(normalized)
        if match:
            return int(match.group(1)), match.group(2)

    match = TRIM_SUBJECT_PATTERN.match(normalized)
    trimmed = match.group(1) if match else normalized
    trimmed = trimmed.strip() or normalized.strip() or "untitled"
    return fallback_idx, trimmed


def ensure_maildir(maildir_path: Path) -> None:
    if not maildir_path.is_dir():
        raise FileNotFoundError(f"missing Maildir: {maildir_path}")

    for subdir in ("cur", "new", "tmp"):
        child = maildir_path / subdir
        if not child.is_dir():
            raise ValueError(f"not a Maildir (missing {subdir}/): {maildir_path}")


def unique_filename(output_dir: Path, stem: str, used_names: set[str]) -> str:
    candidate = f"{stem}.patch"
    suffix = 2
    while candidate in used_names or (output_dir / candidate).exists():
        candidate = f"{stem}-{suffix}.patch"
        suffix += 1
    used_names.add(candidate)
    return candidate


def write_patch(output_dir: Path, filename: str, message: Message) -> None:
    patch_path = output_dir / filename
    with patch_path.open("wb") as patch_file:
        patch_file.write(message.as_bytes(unixfrom=True))


def load_maildir_messages(maildir_path: Path) -> list[tuple[str, Message]]:
    source = mailbox.Maildir(str(maildir_path), factory=None, create=False)
    keys = sorted(source.iterkeys())
    return [(key, source[key]) for key in keys]


def main() -> int:
    args = parse_args()
    maildir_path = Path(args.maildir).resolve()
    output_dir = Path(args.output_dir).resolve()

    try:
        ensure_maildir(maildir_path)
    except (FileNotFoundError, ValueError) as exc:
        print(exc, file=sys.stderr)
        return 2

    output_dir.mkdir(parents=True, exist_ok=True)

    try:
        messages = load_maildir_messages(maildir_path)
    except OSError as exc:
        print(f"failed to read Maildir {maildir_path}: {exc}", file=sys.stderr)
        return 2

    if not messages:
        print(f"Maildir is empty: {maildir_path}", file=sys.stderr)
        return 1

    outputs: list[OutputPatch] = []
    used_names: set[str] = set()
    unknown_idx = UNKNOWN_PATCH_START
    written_count = 0

    for message_idx, (_, message) in enumerate(messages, start=1):
        subject = message.get("subject")
        if subject is None:
            print(f"warning: message {message_idx} is missing Subject, skipping", file=sys.stderr)
            continue

        patch_no, subject_text = parse_patch_subject(subject, unknown_idx)
        if patch_no == unknown_idx:
            unknown_idx += 1

        filename_stem = f"{patch_no:04d}-{format_subject(subject_text)}"
        filename = unique_filename(output_dir, filename_stem, used_names)
        write_patch(output_dir, filename, message)
        outputs.append(OutputPatch(sort_key=(patch_no, message_idx), filename=filename))
        written_count += 1

    if written_count == 0:
        print("No messages with usable Subject headers were written", file=sys.stderr)
        return 1

    if written_count > 1:
        series_path = output_dir / "series"
        with series_path.open("w", encoding="utf-8") as series_file:
            for patch in sorted(outputs, key=lambda item: item.sort_key):
                series_file.write(f"{patch.filename}\n")

    print(f"Wrote {written_count} patch{'es' if written_count != 1 else ''} to {output_dir}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
