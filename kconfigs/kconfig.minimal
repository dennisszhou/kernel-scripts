# Minimal kernel config fragment for QEMU x86_64 boot
#
# Usage:
#   cp kconfig.minimal .config
#   kbuild olddefconfig      # fills in remaining defaults
#   kbuild -j$(nproc)
#
# Or using merge_config:
#   kbuild KCONFIG_ALLCONFIG=kconfig.minimal allnoconfig
#
# This gives you: serial console, virtio disk/net, ext4, initramfs,
# and not much else. Boots in under 2 seconds on QEMU.

#----------------------------------------------------------------------
# Core / boot
#----------------------------------------------------------------------
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_EMBEDDED=y
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y

#----------------------------------------------------------------------
# Processor / platform — basic QEMU x86_64
#----------------------------------------------------------------------
CONFIG_HYPERVISOR_GUEST=y
CONFIG_KVM_GUEST=y
CONFIG_PARAVIRT=y

#----------------------------------------------------------------------
# Block layer
#----------------------------------------------------------------------
CONFIG_BLOCK=y

#----------------------------------------------------------------------
# Serial console (primary output for headless QEMU)
#----------------------------------------------------------------------
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

#----------------------------------------------------------------------
# Virtio (disk, net, console — the QEMU essentials)
#----------------------------------------------------------------------
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_MMIO=y
CONFIG_HW_RANDOM_VIRTIO=y

#----------------------------------------------------------------------
# SCSI (needed by some QEMU disk backends)
#----------------------------------------------------------------------
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y

#----------------------------------------------------------------------
# Filesystems
#----------------------------------------------------------------------
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

#----------------------------------------------------------------------
# Initramfs support
#----------------------------------------------------------------------
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_RD_XZ=y

#----------------------------------------------------------------------
# Networking (minimal — just enough for virtio-net + basic IP)
#----------------------------------------------------------------------
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y

#----------------------------------------------------------------------
# Misc required bits
#----------------------------------------------------------------------
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_INOTIFY_USER=y

#----------------------------------------------------------------------
# Disable things we definitely don't need
#----------------------------------------------------------------------
# CONFIG_SOUND is not set
# CONFIG_USB is not set
# CONFIG_WLAN is not set
# CONFIG_WIRELESS is not set
# CONFIG_BLUETOOTH is not set
# CONFIG_INPUT_MOUSE is not set
# CONFIG_INPUT_KEYBOARD is not set
# CONFIG_VGA_CONSOLE is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_SWAP is not set
# CONFIG_NFS_FS is not set
# CONFIG_SECURITY_SELINUX is not set
# CONFIG_AUDIT is not set
